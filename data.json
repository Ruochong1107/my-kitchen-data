          "qty": "适量"
        },
        {
          "id": "i30",
          "qty": "可选"
        }
      ],
      "steps": [
        "青提对半切，加橄榄油、百里香、一点盐拌匀",
        "烤箱200°C烤15-20分钟至微微焦糖化",
        "法棍对半切，入烤箱复烤至表面酥脆",
        "将Burrata撕开铺在法棍上",
        "铺上烤好的青提",
        "撒黑胡椒，再淋少许橄榄油（喜欢黑醋可加几滴）"
      ]
    }
