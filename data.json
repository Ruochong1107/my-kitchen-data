  "recipes": [
    {
      "id": "r1",
      "name": "红烧肉",
      "category": "家常菜",
      "mealTime": "正餐",
      "cookTime": "90分钟",
      "ingredients": [
        {
          "id": "i1",
          "qty": "500g"
        },
        {
          "id": "i2",
          "qty": "2勺"
        },
        {
          "id": "i3",
          "qty": "1勺"
        },
        {
          "id": "i4",
          "qty": "30g"
        },
        {
          "id": "i5",
          "qty": "2个"
        },
        {
          "id": "i6",
          "qty": "1段"
        },
        {
          "id": "i13",
          "qty": "3片"
        }
      ],
      "steps": [
        "五花肉切方块，冷水下锅焯水去腥，捞出洗净",
        "锅中放冰糖小火炒糖色，加入肉块翻炒上色",
        "加老抽、生抽、八角、桂皮、姜片，加热水没过肉",
        "大火烧开后转小火焖煮60分钟",
        "大火收汁至浓稠，装盘"
      ]
    },
    {
      "id": "r2",
      "name": "麻婆豆腐",
      "category": "川菜",
      "mealTime": "正餐",
      "cookTime": "20分钟",
      "ingredients": [
        {
          "id": "i8",
          "qty": "1块"
        },
        {
          "id": "i9",
          "qty": "100g"
        },
        {
          "id": "i10",
          "qty": "2勺"
        },
        {
          "id": "i11",
          "qty": "1勺"
        },
        {
          "id": "i12",
          "qty": "3瓣"
        },
        {
          "id": "i13",
          "qty": "2片"
        },
        {
          "id": "i3",
          "qty": "1勺"
        }
      ],
      "steps": [
        "豆腐切小块，加盐水中泡5分钟，捞出备用",
        "锅热放油，炒香豆瓣酱至出红油",
        "加肉末炒散，放蒜末姜末炒香",
        "加适量水，放入豆腐，轻轻推动",
        "调生抽，小火煮3分钟，撒花椒粉，勾薄芡出锅"
      ]
    },
    {
      "id": "r3",
      "name": "番茄炒蛋",
      "category": "家常菜",
      "mealTime": "正餐",
      "cookTime": "15分钟",
      "ingredients": [
        {
          "id": "i14",
          "qty": "2个"
        },
        {
          "id": "i7",
          "qty": "3个"
        },
        {
          "id": "i15",
          "qty": "1勺"
        }
      ],
      "steps": [
        "鸡蛋打散加少许盐，西红柿切块备用",
        "锅热多放油，倒入蛋液，半凝固时划散盛出",
        "锅中留油，下西红柿大火翻炒出汁",
        "加入番茄酱增色提味",
        "倒入鸡蛋，加盐糖调味，翻炒均匀出锅"
      ]
    },
    {
      "id": "r4",
      "name": "帕火番茄布里吐司",
      "category": "西餐",
      "mealTime": "早餐",
      "cookTime": "15分钟",
      "ingredients": [
        {
          "id": "i16",
